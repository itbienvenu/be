{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Recruiter Profile Schema",
  "type": "object",
  "properties": {
    "company_name": {
      "type": "string",
      "minLength": 2
    },
    "industry": {
      "type": "string"
    },
    "website": {
      "type": "string",
      "format": "uri"
    },
    "location": {
      "type": "object",
      "properties": {
        "address": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "country": {
          "type": "string"
        }
      },
      "required": [
        "city",
        "country"
      ]
    },
    "bio": {
      "type": "string",
      "maxLength": 1000
    },
    "company_logo": {
      "type": "string",
      "format": "uri"
    },
    "social_links": {
      "type": "object",
      "properties": {
        "linkedin": {
          "type": "string",
          "format": "uri"
        },
        "twitter": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  },
  "required": [
    "company_name",
    "industry",
    "location"
  ]
}