{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Auth Schema",
    "definitions": {
        "login": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$"
                },
                "password": {
                    "type": "string",
                    "minimum": 8,
                    "maximum": 128
                }
            }
        },
        "register": {
            "type": "object",
            "required": [
                "name",
                "email",
                "password",
                "role"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "minimum": 3,
                    "maximum": 100
                },
                "email": {
                    "type": "string",
                    "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$"
                },
                "password": {
                    "type": "string",
                    "minLength": 8,
                    "maxLength": 128
                },
                "role": {
                    "type": "string",
                    "enum": [
                        "applicant",
                        "recruiter"
                    ]
                }
            }
        },
        "logout": {
            "type": "object",
            "required": [
                "token"
            ],
            "properties": {
                "token": {
                    "type": "string"
                }
            }
        },
        "RegisterResponse": {
            "oneOf": [
                {
                    "type": "object",
                    "properties": {
                        "success": {
                            "type": "boolean"
                        },
                        "message": {
                            "type": "string"
                        },
                        "data": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string"
                                },
                                "email": {
                                    "type": "string"
                                },
                                "role": {
                                    "type": "string",
                                    "enum": [
                                        "applicant",
                                        "recruiter"
                                    ]
                                }
                            }
                        }
                    },
                    "required": [
                        "success",
                        "message",
                        "data"
                    ]
                },
                {
                    "type": "object",
                    "properties": {
                        "success": {
                            "type": "boolean"
                        },
                        "message": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "success",
                        "message"
                    ]
                }
            ]
        }
    }
}