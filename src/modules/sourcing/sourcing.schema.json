
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["jobId", "columnMapping"],
  "properties": {
    "jobId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{24}$",
      "description": "MongoDB ObjectId"
    },
    "columnMapping": {
      "type": "object",
      "properties": {
        "first_name": { "type": "string" },
        "last_name": { "type": "string" },
        "email": { "type": "string" },
        "resume_url": { "type": "string" },
        "phone": { "type": "string" },
        "headline": { "type": "string" },
        "bio": { "type": "string" },
        "linkedin": { "type": "string" },
        "github": { "type": "string" }
      }
    },
    "skipInvalidRows": {
      "type": "boolean",
      "default": false
    }
  }
}
